<ui:FluentWindow x:Class="TechSupport.Console.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:TechSupport.Console.ViewModels"
        xmlns:views="clr-namespace:TechSupport.Console.Views"
        Title="TechSupport Console"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="TechSupport Console" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="240" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{DynamicResource ApplicationBackgroundBrush}" Padding="12">
                <DockPanel LastChildFill="True">
                    <ui:TextBlock DockPanel.Dock="Top" FontTypography="Subtitle" Text="Quick connect" Margin="0,0,0,8" />
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="72" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" PlaceholderText="host or pairing code"
                                    Text="{Binding QuickConnectHost, UpdateSourceTrigger=PropertyChanged}" />
                        <ui:TextBox Grid.Column="1" Margin="6,0,0,0"
                                    Text="{Binding QuickConnectPort, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                    <ui:Button DockPanel.Dock="Top"
                              Appearance="Primary"
                              HorizontalAlignment="Stretch"
                              Content="Connect"
                              Icon="{ui:SymbolIcon Symbol=Link24}"
                              Command="{Binding ConnectCommand}"
                              Margin="0,0,0,16" />

                    <ui:TextBlock DockPanel.Dock="Top" FontTypography="Subtitle" Text="Saved" Margin="0,0,0,8" />
                    <ListBox ItemsSource="{Binding SavedConnections}"
                             SelectedItem="{Binding SelectedConnection}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,4">
                                    <ui:TextBlock FontTypography="BodyStrong" Text="{Binding Label}" />
                                    <ui:TextBlock FontTypography="Caption" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{Binding Host}" />
                                        <Run Text=":" />
                                        <Run Text="{Binding Port}" />
                                    </ui:TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

            <Grid Grid.Column="2">
                <views:RemoteDesktopView DataContext="{Binding ActiveSession}" />

                <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                        Visibility="{Binding ActiveSession, Converter={StaticResource NullToVisible}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="DesktopArrowRight24" FontSize="64"
                                       HorizontalAlignment="Center" Margin="0,0,0,16"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <ui:TextBlock FontTypography="Title" Text="No active session"
                                      HorizontalAlignment="Center" />
                        <ui:TextBlock FontTypography="Body"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                      Text="Enter a host or pick a saved customer to connect."
                                      HorizontalAlignment="Center" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Padding="12,6" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBlock Grid.Column="0" FontTypography="Caption"
                              Text="{Binding StatusText}"
                              VerticalAlignment="Center" />
                <ui:TextBlock Grid.Column="1" FontTypography="Caption"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              VerticalAlignment="Center">
                    <Run Text="latency " /><Run Text="{Binding ActiveSession.LatencyMs, StringFormat={}{0:F0} ms, FallbackValue=—}" />
                </ui:TextBlock>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
