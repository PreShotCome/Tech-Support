<Page x:Class="TechSupport.Console.Views.Pages.CustomersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="Customers">

    <Grid DataContext="{Binding Customers}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <DockPanel Grid.Column="0" Background="{DynamicResource ApplicationBackgroundBrush}" LastChildFill="True">
            <Grid DockPanel.Dock="Top" Margin="12,12,12,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox Grid.Column="0"
                            PlaceholderText="Search…"
                            Icon="{ui:SymbolIcon Symbol=Search24}"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                <ui:Button Grid.Column="1" Margin="6,0,0,0"
                           Appearance="Primary"
                           Icon="{ui:SymbolIcon Symbol=Add24}"
                           Command="{Binding NewCommand}" />
            </Grid>

            <ListBox ItemsSource="{Binding FilteredView}"
                     SelectedItem="{Binding Selected}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="4,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="32" Height="32"
                                    CornerRadius="16"
                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                    HorizontalAlignment="Left">
                                <ui:TextBlock Text="{Binding Initials}"
                                              Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              FontTypography="BodyStrong" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <ui:TextBlock FontTypography="BodyStrong" Text="{Binding Name}"
                                              TextTrimming="CharacterEllipsis" />
                                <ui:TextBlock FontTypography="Caption"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              Text="{Binding Organization}"
                                              TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>

        <GridSplitter Grid.Column="1" Width="1"
                      Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
            <Grid Margin="24">
                <Grid.Visibility>
                    <Binding Path="Selected" Converter="{StaticResource NotNullToVisible}" />
                </Grid.Visibility>

                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <Border Width="56" Height="56" CornerRadius="28"
                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                VerticalAlignment="Center">
                            <ui:TextBlock Text="{Binding Selected.Initials}"
                                          Foreground="{DynamicResource TextOnAccentFillColorPrimaryBrush}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Center"
                                          FontSize="22"
                                          FontTypography="Title" />
                        </Border>
                        <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                            <ui:TextBlock FontTypography="Title" Text="{Binding Selected.Name}" />
                            <ui:TextBlock FontTypography="Caption"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Text="{Binding Selected.Organization, TargetNullValue='No organization'}" />
                        </StackPanel>
                        <ui:Button Margin="20,0,0,0"
                                  Appearance="Danger"
                                  Icon="{ui:SymbolIcon Symbol=Delete24}"
                                  Content="Delete"
                                  VerticalAlignment="Center"
                                  Command="{Binding DeleteCommand}" />
                    </StackPanel>

                    <ui:CardExpander Header="Contact" Margin="0,0,0,12" IsExpanded="True">
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,8,8">
                                <ui:TextBlock FontTypography="Caption" Text="Name" />
                                <ui:TextBox Text="{Binding Selected.Name, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="0" Margin="8,0,0,8">
                                <ui:TextBlock FontTypography="Caption" Text="Organization" />
                                <ui:TextBox Text="{Binding Selected.Organization, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                            </StackPanel>
                            <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,8,8">
                                <ui:TextBlock FontTypography="Caption" Text="Phone" />
                                <ui:TextBox Text="{Binding Selected.PhoneNumber, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Grid.Row="1" Margin="8,0,0,8">
                                <ui:TextBlock FontTypography="Caption" Text="Email" />
                                <ui:TextBox Text="{Binding Selected.Email, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                            </StackPanel>
                        </Grid>
                    </ui:CardExpander>

                    <ui:CardExpander Header="Notes" Margin="0,0,0,12" IsExpanded="True">
                        <ui:TextBox Margin="0,8,0,0"
                                    AcceptsReturn="True"
                                    TextWrapping="Wrap"
                                    MinHeight="120"
                                    VerticalScrollBarVisibility="Auto"
                                    Text="{Binding Selected.Notes, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}" />
                    </ui:CardExpander>

                    <ui:CardExpander Header="Machines" Margin="0,0,0,12" IsExpanded="True">
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <ui:Button Icon="{ui:SymbolIcon Symbol=Add24}"
                                          Content="Add machine"
                                          Command="{Binding AddConnectionCommand}" />
                                <ui:Button Margin="8,0,0,0"
                                          Appearance="Primary"
                                          Icon="{ui:SymbolIcon Symbol=Link24}"
                                          Content="Connect"
                                          Command="{Binding ConnectCommand}" />
                                <ui:Button Margin="8,0,0,0"
                                          Appearance="Secondary"
                                          Icon="{ui:SymbolIcon Symbol=Delete24}"
                                          Content="Remove"
                                          Command="{Binding RemoveConnectionCommand}" />
                            </StackPanel>
                            <DataGrid ItemsSource="{Binding Selected.Connections}"
                                      SelectedItem="{Binding SelectedConnection}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      GridLinesVisibility="None"
                                      HeadersVisibility="Column"
                                      Background="Transparent"
                                      BorderThickness="0">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Label" Binding="{Binding Label, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTextColumn Header="Host" Binding="{Binding Host, UpdateSourceTrigger=PropertyChanged}" Width="*" />
                                    <DataGridTextColumn Header="Port" Binding="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Width="80" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ui:CardExpander>

                    <ui:CardExpander Header="Session history" Margin="0,0,0,12" IsExpanded="False">
                        <DataGrid Margin="0,8,0,0"
                                  ItemsSource="{Binding Selected.History}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="None"
                                  HeadersVisibility="Column"
                                  Background="Transparent"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Started" Binding="{Binding StartedUtc, StringFormat=g}" Width="*" />
                                <DataGridTextColumn Header="Duration" Binding="{Binding Duration, StringFormat=hh\\:mm\\:ss}" Width="120" />
                                <DataGridTextColumn Header="Outcome" Binding="{Binding Outcome}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </ui:CardExpander>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <Border Grid.Column="2"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Border.Visibility>
                <Binding Path="Selected" Converter="{StaticResource NullToVisible}" />
            </Border.Visibility>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="340">
                <ui:SymbolIcon Symbol="People24" FontSize="56"
                               HorizontalAlignment="Center" Margin="0,0,0,16"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                <ui:TextBlock FontTypography="Title" Text="No customer selected"
                              HorizontalAlignment="Center" />
                <ui:TextBlock FontTypography="Body"
                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                              TextAlignment="Center"
                              TextWrapping="Wrap"
                              Margin="0,8,0,0"
                              Text="Pick a customer on the left, or add a new one with the + button." />
            </StackPanel>
        </Border>
    </Grid>
</Page>
