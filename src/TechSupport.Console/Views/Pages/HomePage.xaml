<Page x:Class="TechSupport.Console.Views.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:views="clr-namespace:TechSupport.Console.Views"
      Title="Home">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Padding="20" Background="{DynamicResource ApplicationBackgroundBrush}">
            <DockPanel LastChildFill="True">
                <ui:TextBlock DockPanel.Dock="Top" FontTypography="Subtitle" Text="Quick connect" Margin="0,0,0,8" />
                <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="72" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" PlaceholderText="host or pairing code"
                                Text="{Binding Home.QuickConnectHost, UpdateSourceTrigger=PropertyChanged}" />
                    <ui:TextBox Grid.Column="1" Margin="6,0,0,0"
                                Text="{Binding Home.QuickConnectPort, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>
                <ui:Button DockPanel.Dock="Top"
                           Appearance="Primary"
                           HorizontalAlignment="Stretch"
                           Content="Connect"
                           Icon="{ui:SymbolIcon Symbol=Link24}"
                           Command="{Binding Home.ConnectCommand}"
                           Margin="0,0,0,16" />

                <ui:TextBlock DockPanel.Dock="Top" FontTypography="Subtitle" Text="Recent" Margin="0,0,0,8" />
                <ListBox ItemsSource="{Binding Home.Recent}"
                         BorderThickness="0"
                         Background="Transparent">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Button Padding="6"
                                    HorizontalContentAlignment="Stretch"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    Command="{Binding DataContext.Home.ConnectRecentCommand,
                                              RelativeSource={RelativeSource AncestorType=Page}}"
                                    CommandParameter="{Binding}">
                                <StackPanel>
                                    <ui:TextBlock FontTypography="BodyStrong" Text="{Binding Customer.Name}" />
                                    <ui:TextBlock FontTypography="Caption"
                                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                        <Run Text="{Binding Connection.Host}" /><Run Text=":" /><Run Text="{Binding Connection.Port}" />
                                    </ui:TextBlock>
                                </StackPanel>
                            </Button>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <views:RemoteDesktopView DataContext="{Binding ActiveSession}"
                                     Visibility="{Binding ActiveSession, Converter={StaticResource NotNullToVisible}}" />

            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    Visibility="{Binding ActiveSession, Converter={StaticResource NullToVisible}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" MaxWidth="360">
                    <ui:SymbolIcon Symbol="DesktopArrowRight24" FontSize="64"
                                   HorizontalAlignment="Center" Margin="0,0,0,16"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                    <ui:TextBlock FontTypography="Title" Text="No active session"
                                  HorizontalAlignment="Center" />
                    <ui:TextBlock FontTypography="Body"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  TextAlignment="Center"
                                  TextWrapping="Wrap"
                                  Text="Enter a host or pairing code on the left, or open Customers to start from a saved record."
                                  Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <Border VerticalAlignment="Top" HorizontalAlignment="Right" Margin="12"
                    Background="{DynamicResource SystemFillColorSolidNeutralBackgroundBrush}"
                    CornerRadius="6" Padding="8,4"
                    Visibility="{Binding ActiveSession, Converter={StaticResource NotNullToVisible}}">
                <ui:Button Appearance="Secondary"
                          Content="Disconnect"
                          Icon="{ui:SymbolIcon Symbol=PlugDisconnected24}"
                          Command="{Binding Home.DisconnectCommand}" />
            </Border>
        </Grid>
    </Grid>
</Page>
