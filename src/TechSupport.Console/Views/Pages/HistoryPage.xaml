<Page x:Class="TechSupport.Console.Views.Pages.HistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="History">

    <DockPanel Margin="24" DataContext="{Binding History}">
        <ui:TextBlock DockPanel.Dock="Top" FontTypography="Title" Text="Session history" Margin="0,0,0,16" />
        <DataGrid ItemsSource="{Binding AllRows}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="None"
                  HeadersVisibility="Column"
                  Background="Transparent"
                  BorderThickness="0"
                  RowHeight="34">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Customer" Binding="{Binding Customer.Name}" Width="*" />
                <DataGridTextColumn Header="Host" Binding="{Binding Record.Host}" Width="*" />
                <DataGridTextColumn Header="Started" Binding="{Binding Record.StartedUtc, StringFormat=g}" Width="180" />
                <DataGridTextColumn Header="Duration" Binding="{Binding Record.Duration, StringFormat=hh\\:mm\\:ss}" Width="120" />
                <DataGridTextColumn Header="Outcome" Binding="{Binding Record.Outcome}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Page>
