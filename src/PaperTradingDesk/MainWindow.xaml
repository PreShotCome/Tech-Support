<ui:FluentWindow x:Class="PaperTradingDesk.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Paper Trading Desk"
        Width="980" Height="640"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Paper Trading Desk" />

        <!-- Equity row -->
        <Border Grid.Row="1" Margin="20,16,20,8" Padding="16"
                Background="{DynamicResource SystemFillColorSolidNeutralBackgroundBrush}"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <ui:TextBlock FontTypography="Caption" Text="EQUITY"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:TextBlock FontTypography="Title" Text="{Binding Equity, StringFormat=C0}" />
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <ui:TextBlock FontTypography="Caption" Text="CASH"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:TextBlock FontTypography="Title" Text="{Binding Cash, StringFormat=C0}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <ui:TextBlock FontTypography="Caption" Text="POSITIONS"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:TextBlock FontTypography="Title" Text="{Binding PortfolioValue, StringFormat=C0}" />
                </StackPanel>
                <StackPanel Grid.Column="3">
                    <ui:TextBlock FontTypography="Caption" Text="P&amp;L"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    <ui:TextBlock FontTypography="Title">
                        <Run Text="{Binding Pnl, StringFormat=C0}" />
                        <Run FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                            <Run.Text>
                                <Binding Path="PnlPercent" StringFormat=" ({0:F2}%)" />
                            </Run.Text>
                        </Run>
                    </ui:TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="20,8,20,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Watchlist -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <ui:TextBlock DockPanel.Dock="Top" FontTypography="Subtitle" Text="Watchlist" Margin="0,0,0,8" />
                <ListBox ItemsSource="{Binding Watchlist}"
                         SelectedItem="{Binding Selected}"
                         BorderThickness="0"
                         Background="Transparent"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <ui:TextBlock Grid.Column="0" FontTypography="BodyStrong" Text="{Binding Symbol}" />
                                <ui:TextBlock Grid.Column="1" Text="{Binding LastPrice, StringFormat=C2}" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- Order + positions -->
            <DockPanel Grid.Column="1">
                <Border DockPanel.Dock="Top" Margin="0,0,0,12" Padding="16"
                        Background="{DynamicResource SystemFillColorSolidNeutralBackgroundBrush}"
                        CornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <ui:TextBlock FontTypography="Caption" Text="ORDER" />
                            <ui:TextBlock FontTypography="Subtitle" Text="{Binding Selected.Symbol, FallbackValue='(none)'}" />
                            <ui:TextBlock FontTypography="Caption"
                                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                          Text="{Binding Selected.LastPrice, StringFormat='Last: {0:C2}', FallbackValue=''}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <ui:TextBlock FontTypography="Caption" Text="QTY" />
                            <ui:TextBox Text="{Binding OrderQty}" />
                        </StackPanel>

                        <ui:Button Grid.Column="2" Margin="12,0,8,0" MinWidth="90"
                                  Appearance="Success"
                                  Content="Buy"
                                  Command="{Binding BuyCommand}" />
                        <ui:Button Grid.Column="3" MinWidth="90"
                                  Appearance="Danger"
                                  Content="Sell"
                                  Command="{Binding SellCommand}" />
                    </Grid>
                </Border>

                <ui:TextBlock DockPanel.Dock="Top" FontTypography="Subtitle" Text="Positions" Margin="0,0,0,8" />
                <DataGrid ItemsSource="{Binding Positions}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          Background="Transparent"
                          BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Symbol" Binding="{Binding Symbol}" Width="*" />
                        <DataGridTextColumn Header="Qty" Binding="{Binding Qty}" Width="80" />
                        <DataGridTextColumn Header="Avg" Binding="{Binding AvgPrice, StringFormat=C2}" Width="100" />
                        <DataGridTextColumn Header="Value" Binding="{Binding MarketValue, StringFormat=C2}" Width="120" />
                        <DataGridTextColumn Header="P&amp;L" Binding="{Binding UnrealizedPnl, StringFormat=C2}" Width="120" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>

        <Border Grid.Row="3" Padding="20,8" BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <ui:TextBlock FontTypography="Caption" Text="{Binding StatusText}" />
        </Border>
    </Grid>
</ui:FluentWindow>
