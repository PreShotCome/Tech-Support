<ui:FluentWindow x:Class="TechSupport.ConsentPrompt.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Remote support request"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="True"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="Remote support request" />

        <StackPanel Grid.Row="1" Margin="32,16,32,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <ui:SymbolIcon Symbol="ShieldCheckmark24" FontSize="32"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               VerticalAlignment="Center" />
                <ui:TextBlock FontTypography="Title"
                              Margin="12,0,0,0"
                              VerticalAlignment="Center"
                              Text="Allow remote support?" />
            </StackPanel>

            <ui:TextBlock FontTypography="Body" Margin="0,0,0,12">
                <Run Text="A technician named " />
                <Run FontWeight="SemiBold" Text="{Binding TechnicianName, Mode=OneWay}" />
                <Run Text=" wants to view and control your screen." />
            </ui:TextBlock>

            <Border Background="{DynamicResource SystemFillColorSolidNeutralBackgroundBrush}"
                    CornerRadius="6" Padding="12" Margin="0,0,0,12">
                <StackPanel>
                    <ui:TextBlock FontTypography="Caption"
                                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                  Text="Reason given" />
                    <ui:TextBlock FontTypography="Body" Text="{Binding Reason, Mode=OneWay}" TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <ui:TextBlock FontTypography="Caption"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          TextWrapping="Wrap"
                          Text="You can end the session at any time from the system tray. Every action the technician takes is logged on this machine." />

            <ui:TextBlock x:Name="Countdown"
                          Margin="0,12,0,0"
                          FontTypography="Caption"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
        </StackPanel>

        <Grid Grid.Row="2" Margin="32,0,32,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="1"
                      Content="Deny"
                      Appearance="Secondary"
                      Click="OnDeny"
                      MinWidth="100"
                      Margin="0,0,8,0" />
            <ui:Button Grid.Column="2"
                      Content="Allow"
                      Appearance="Primary"
                      Icon="{ui:SymbolIcon Symbol=Checkmark24}"
                      Click="OnAllow"
                      MinWidth="100"
                      IsDefault="True" />
        </Grid>
    </Grid>
</ui:FluentWindow>
